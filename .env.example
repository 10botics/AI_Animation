# =============================================================================
# Fal.ai API key — TEMPLATE ONLY (safe to commit)
# =============================================================================
# 1. Copy this file to `.env` in the same folder (project root).
# 2. In `.env`, replace the placeholder after FAL_KEY= with your real key.
#
# Where to get your key:
#   https://fal.ai/dashboard/keys  (or Dashboard → API Keys on fal.ai)
#
# Never commit `.env` — it is listed in `.gitignore`.
# Never paste your key into chat or share it.
# =============================================================================

FAL_KEY=

# Optional — AI Animation Studio dashboard port (default 8501)
# Use a different port to run two instances at once (e.g. 8502).
# STUDIO_PORT=8502

# Optional — default chapter folder under Comic Source/ for this instance
# STUDIO_CHAPTER=Chapter-81
