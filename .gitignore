*.mp4
*.webm
*.mov
*.mkv
*.m4v
*.avi
*.gif

# Stray audio exports (voice WAV/MP3 live under outputs/ or voice_refs/)
*.wav
*.mp3
*.flac
*.aac

# Mentor pack ZIP — built locally; never commit (manga + voice refs)
AI_Animation-mentor-pack.zip
*-mentor-pack.zip

