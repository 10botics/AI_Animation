# =============================================================================
# Secrets — never commit keys (use .env.example as the template)
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Generated / cache (reproducible with scripts + API key)
# =============================================================================
outputs/

# Stills, iterations, approved Final — all local-only (use --start-image / --ref for I2V)
Tests/

# Timeline / scratch exports (if present)
cuts/

# =============================================================================
# Media — manga sources, crops, renders (generic image→animation workflow)
# =============================================================================
# Panel crops and any future ref/ folders
panels/

# Raw chapter scans (keep stage_*.md etc.); supports Frierien-chapter### or similar
Frierien-chapter*/**/*.jpg
Frierien-chapter*/**/*.jpeg
Frierien-chapter*/**/*.JPG
Frierien-chapter*/**/*.JPEG
Frierien-chapter*/**/*.png
Frierien-chapter*/**/*.webp

# Stray page dumps at repo root
/*.jpg
/*.jpeg
/*.JPG
/*.JPEG
/*.png
/*.webp

# Videos (if saved outside outputs/)
*.mp4
*.webm
*.mov
*.mkv

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
dist/
build/

