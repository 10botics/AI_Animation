# =============================================================================
# Secrets — never commit keys (use .env.example as the template)
# =============================================================================
.env
.env.*
!.env.example

# MiniMax / TTS — local voice IDs + raw reference recordings (do not commit)
voice_registry.local.json
voice_refs/
video source/

# Regenerate via scripts/prepare_*_qwen_ref.py (keep README only)
Voice Reference/**
!Voice Reference/README.md

# =============================================================================
# HR / intern applications — personal data (CVs, emails, spreadsheets)
# =============================================================================
Intern_applications/
*.eml

# =============================================================================
# Generated / cache (reproducible with scripts + API key)
# =============================================================================
outputs/

# Per-shot production artifacts (stills, voice, video, lip-sync, sfx)
shots/

# Chapter BGM (prototype / assembly)
audio/

# Stills, iterations — legacy layout (optional after normalize_artifacts.py)
Tests/

# Timeline / scratch exports (if present)
cuts/

# Student workbook PDFs — rebuild from docs/cursor-student-workbook-en.md
docs/cursor-student-workbook*.pdf

# Character portrait refs — ship via mentor pack, not git
docs/reference/

# Google Drive / editor temp debris under chapter folders
**/.tmp.driveupload/

# =============================================================================
# Comic Source / lesson content — ship via mentor pack (build_mentor_pack_zip.py), not git
# =============================================================================
# Panel crops and any future ref/ folders
panels/

# Comic Source — chapter folders (gitignored except this README)
Comic Source/**
!Comic Source/README.md

# Stray legacy chapter folders at repo root (gitignored; still discovered if stage_02 present)
Chapter-*/
Frierien-chapter*/
chapter-*/
ch[0-9][0-9][0-9]/

# Clip / demo deliverables (not needed to run the pipeline on a new chapter)
subs/

# Drop folders for ad-hoc sources (any image → animation)
inputs/
sources/

# Stray page dumps at repo root
/*.jpg
/*.jpeg
/*.JPG
/*.JPEG
/*.png
/*.webp

